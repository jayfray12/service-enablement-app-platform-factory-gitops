apiVersion: argoproj.io/v1beta1
kind: ArgoCD
metadata:
  name: openshift-gitops
  namespace: {{ etx_gitops_namespace }}
spec:
  rbac:
    defaultPolicy: role:readonly
    scopes: '[groups, preferred_username]'
    policy: |
      g, argocd-admins, role:admin
      g, system:cluster-admins, role:admin
      g, cluster-admins, role:admin
      g, admin, role:admin
  resourceHealthChecks:
  - group: k8s.keycloak.org
    kind: Keycloak
    check: |
      hs = {}
      if obj.status ~= nil then
        if obj.status.conditions ~= nil then
          for i, condition in ipairs(obj.status.conditions) do
            if condition.type == "Ready" and condition.status == "True" then
              hs.status = "Healthy"
              hs.message = "Keycloak is ready"
              return hs
            end
          end
        end
      end
      hs.status = "Progressing"
      hs.message = "Keycloak is not ready"
      return hs
  - group: k8s.keycloak.org
    kind: KeycloakRealmImport
    check: |
      hs = {}
      if obj.status ~= nil then
        if obj.status.conditions ~= nil then
          for i, condition in ipairs(obj.status.conditions) do
            if condition.type == "Done" and condition.status == "True" then
              hs.status = "Healthy"
              hs.message = "Realm imported successfully"
              return hs
            end
          end
        end
      end
      hs.status = "Progressing"
      hs.message = "Realm import in progress"
      return hs
  - group: quay.redhat.com
    kind: QuayRegistry
    check: |
      hs = {}
      if obj.status ~= nil then
        if obj.status.conditions ~= nil then
          for i, condition in ipairs(obj.status.conditions) do
            if condition.type == "Available" and condition.status == "True" then
              hs.status = "Healthy"
              hs.message = "Quay is available"
              return hs
            end
          end
        end
      end
      hs.status = "Progressing"
      hs.message = "Quay is deploying"
      return hs
